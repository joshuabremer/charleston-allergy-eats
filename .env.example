# Copy this file to .env and fill in real values. .env is gitignored.

# Google Maps Platform API key, used by scripts/geocode.ts and scripts/lookup-restaurant.ts.
# Create one at https://console.cloud.google.com/google/maps-apis/credentials and enable both
# the "Geocoding API" and "Places API (New)" for it — each API needs to be enabled separately,
# even though they share the same key.
GOOGLE_MAPS_API_KEY=
